{
	"name": "nebulosa-server",
	"module": "main.ts",
	"type": "module",
	"scripts": {
		"lint": "biome lint --write src/ web/",
		"format": "biome format --write src/ web/",
		"dev": "bun --watch run .",
		"web": "bun run build.ts",
		"compile": "bun build --compile --minify . --outfile nebulosa.exe"
	},
	"dependencies": {
		"@elysiajs/cors": "1.2.0",
		"@elysiajs/cron": "1.2.0",
		"@mantine/charts": "7.17.2",
		"@mantine/core": "7.17.2",
		"@mantine/dates": "7.17.2",
		"@mantine/hooks": "7.17.2",
		"@mantine/notifications": "7.17.2",
		"@tabler/icons-react": "3.31.0",
		"bun-plugin-tailwind": "latest",
		"dayjs": "1.11.13",
		"elysia": "1.2.25",
		"nebulosa": "github:tiagohm/nebulosa.ts",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"recharts": "2.15.1",
		"tailwindcss": "4.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@types/bun": "latest",
		"@types/node": "latest",
		"@types/react": "19.0.10",
		"@types/react-dom": "19.0.4"
	},
	"trustedDependencies": ["@biomejs/biome"]
}
